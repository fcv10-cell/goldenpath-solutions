---
// Official GoldenPath Solutions logo (light/negative version for dark backgrounds).
interface Props {
  class?: string;
}
const { class: cls = "" } = Astro.props;
---

<a href="#top" class={`inline-flex items-center ${cls}`} aria-label="GoldenPath Solutions — home">
  <img
    src="/logo/goldenpath-light.png"
    alt="GoldenPath Solutions"
    width="916"
    height="193"
    class="h-7 w-auto sm:h-8"
  />
</a>
